# ─────────────────────────────────────────────────────────────
#  Grove AI — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Database (Prisma Postgres / Prisma Cloud) ─────────────────
# Get your connection string from https://console.prisma.io
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_API_KEY"

# ── OpenAI ────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
# Set LMSTUDIO_MODE=false to use real OpenAI (recommended for best results)
LMSTUDIO_MODE=false
OPENAI_API_KEY=sk-...your-openai-key-here...

# ── Serper (Web Search) ───────────────────────────────────────
# Free tier: 2,500 searches/month — https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── Hunter.io (Email / Contact Finder) ───────────────────────
# Free tier: 50 searches/month — https://hunter.io
# Leave blank to skip Hunter enrichment
HUNTER_API_KEY=your_hunter_api_key_here

# ── Google Sheets Integration ─────────────────────────────────
# Follow the Google Sheets setup guide in the README to get these values.
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Legacy / Unused ───────────────────────────────────────────
# These are kept for reference but not required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OLLAMA_API_URL=http://localhost:11434
